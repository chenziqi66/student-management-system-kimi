# Django Settings
# ===============

# SECURITY WARNING: keep the secret key used in production secret!
# Generate a new secret key using:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here

# Debug mode (True for development, False for production)
DEBUG=True

# Allowed hosts (comma-separated)
# Development: localhost,127.0.0.1
# Production: yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1


# Database Configuration
# ======================

# Development: django.db.backends.sqlite3
# Production: django.db.backends.mysql or django.db.backends.postgresql
DB_ENGINE=django.db.backends.sqlite3

# Database name (for SQLite, use path like: db.sqlite3)
DB_NAME=db.sqlite3

# Database credentials (required for MySQL/PostgreSQL)
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=


# Email Configuration (Production)
# ================================

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=your-email@example.com


# Security Settings (Production)
# ==============================

# Enable HTTPS redirect
SECURE_SSL_REDIRECT=True

# Admin email for error notifications
ADMIN_EMAIL=admin@example.com
